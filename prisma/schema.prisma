generator client {
  provider        = "prisma-client-js"
  output          = "../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
}

model Supplier {
  id         Int       @id @default(autoincrement())
  name       String    @unique
  contact    String?
  email      String?
  phone      String?
  notes      String?
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  invoices   Invoice[]
  @@map("suppliers")
}

model Ingredient {
  id                     Int                      @id @default(autoincrement())
  name                   String                   @unique
  description            String?
  unit                   String
  current_price_per_unit Float?
  yield_percentage       Float?                   @default(100)
  prep_loss_notes        String?
  par_level              Float?
  par_unit               String?
  created_at             DateTime                 @default(now())
  updated_at             DateTime                 @updatedAt
  price_history          IngredientPriceHistory[]
  invoice_line_items     InvoiceLineItem[]
  recipe_components      RecipeComponent[]
  allergens              IngredientAllergen[]
  stock_count_lines      StockCountLine[]
  waste_logs             WasteLog[]
  @@map("ingredients")
}

model IngredientPriceHistory {
  id             Int        @id @default(autoincrement())
  ingredient_id  Int
  price_per_unit Float
  invoice_id     Int?
  recorded_at    DateTime   @default(now())
  ingredient     Ingredient @relation(fields: [ingredient_id], references: [id], onDelete: Cascade)
  invoice        Invoice?   @relation(fields: [invoice_id], references: [id], onDelete: SetNull)
  @@index([ingredient_id])
  @@index([ingredient_id, recorded_at])
  @@map("ingredient_price_history")
}

model Invoice {
  id            Int               @id @default(autoincrement())
  supplier_id   Int
  invoice_date  DateTime
  reference     String?
  notes         String?
  created_at    DateTime          @default(now())
  updated_at    DateTime          @updatedAt
  supplier      Supplier          @relation(fields: [supplier_id], references: [id])
  line_items    InvoiceLineItem[]
  price_history IngredientPriceHistory[]
  @@index([supplier_id])
  @@index([invoice_date])
  @@map("invoices")
}

model InvoiceLineItem {
  id                       Int        @id @default(autoincrement())
  invoice_id               Int
  ingredient_id            Int
  quantity                 Float
  purchase_unit            String
  total_cost               Float
  price_per_canonical_unit Float?
  created_at               DateTime   @default(now())
  invoice                  Invoice    @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  ingredient               Ingredient @relation(fields: [ingredient_id], references: [id])
  @@index([invoice_id])
  @@index([ingredient_id])
  @@map("invoice_line_items")
}

model Recipe {
  id             Int               @id @default(autoincrement())
  name           String            @unique
  description    String?
  is_sub_recipe  Boolean           @default(false)
  yield_quantity Float             @default(1)
  yield_unit     String            @default("units")
  created_at     DateTime          @default(now())
  updated_at     DateTime          @updatedAt
  components     RecipeComponent[] @relation("RecipeComponents")
  used_in        RecipeComponent[] @relation("SubRecipeUsedIn")
  product        Product?
  steps          RecipeStep[]
  waste_logs     WasteLog[]
  @@map("recipes")
}

model RecipeStep {
  id            Int      @id @default(autoincrement())
  recipe_id     Int
  step_number   Int
  instruction   String
  photo_url     String?
  duration_mins Int?
  created_at    DateTime @default(now())
  recipe        Recipe   @relation(fields: [recipe_id], references: [id], onDelete: Cascade)
  @@index([recipe_id])
  @@map("recipe_steps")
}

model RecipeComponent {
  id            Int         @id @default(autoincrement())
  recipe_id     Int
  ingredient_id Int?
  sub_recipe_id Int?
  quantity      Float
  unit          String
  sort_order    Int         @default(0)
  created_at    DateTime    @default(now())
  recipe        Recipe      @relation("RecipeComponents", fields: [recipe_id], references: [id], onDelete: Cascade)
  ingredient    Ingredient? @relation(fields: [ingredient_id], references: [id], onDelete: SetNull)
  sub_recipe    Recipe?     @relation("SubRecipeUsedIn", fields: [sub_recipe_id], references: [id], onDelete: SetNull)
  @@index([recipe_id])
  @@index([ingredient_id])
  @@index([sub_recipe_id])
  @@map("recipe_components")
}

model Product {
  id               Int            @id @default(autoincrement())
  name             String         @unique
  description      String?
  recipe_id        Int            @unique
  wholesale_price  Float?
  retail_price     Float?
  selling_unit     String?
  is_active        Boolean        @default(true)
  created_at       DateTime       @default(now())
  updated_at       DateTime       @updatedAt
  recipe           Recipe         @relation(fields: [recipe_id], references: [id])
  cost_snapshots   CostSnapshot[]
  @@map("products")
}

model CostSnapshot {
  id                       Int      @id @default(autoincrement())
  product_id               Int
  total_cost               Float
  breakdown_json           String
  triggered_by_invoice_id  Int?
  snapshotted_at           DateTime @default(now())
  product                  Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)
  @@index([product_id])
  @@index([product_id, snapshotted_at])
  @@map("cost_snapshots")
}

model Allergen {
  id           Int                  @id @default(autoincrement())
  key          String               @unique
  display_name String
  ingredients  IngredientAllergen[]
  @@map("allergens")
}

model IngredientAllergen {
  ingredient_id Int
  allergen_id   Int
  ingredient    Ingredient @relation(fields: [ingredient_id], references: [id], onDelete: Cascade)
  allergen      Allergen   @relation(fields: [allergen_id], references: [id], onDelete: Cascade)
  @@id([ingredient_id, allergen_id])
  @@map("ingredient_allergens")
}

model StockCount {
  id          Int              @id @default(autoincrement())
  name        String
  status      String           @default("draft")
  counted_at  DateTime         @default(now())
  notes       String?
  created_at  DateTime         @default(now())
  lines       StockCountLine[]
  @@map("stock_counts")
}

model StockCountLine {
  id               Int         @id @default(autoincrement())
  stock_count_id   Int
  ingredient_id    Int
  counted_quantity Float
  unit             String
  count            StockCount  @relation(fields: [stock_count_id], references: [id], onDelete: Cascade)
  ingredient       Ingredient  @relation(fields: [ingredient_id], references: [id])
  @@index([stock_count_id])
  @@map("stock_count_lines")
}

model WasteLog {
  id            Int         @id @default(autoincrement())
  ingredient_id Int?
  recipe_id     Int?
  quantity      Float
  unit          String
  reason        String
  notes         String?
  cost_at_log   Float?
  logged_at     DateTime    @default(now())
  ingredient    Ingredient? @relation(fields: [ingredient_id], references: [id], onDelete: SetNull)
  recipe        Recipe?     @relation(fields: [recipe_id], references: [id], onDelete: SetNull)
  @@index([logged_at])
  @@map("waste_logs")
}
